# Anthropic (required)
ANTHROPIC_API_KEY=your-anthropic-api-key

# Ahrefs (optional - for keyword data)
AHREFS_API_KEY=your-ahrefs-api-key

# Google Cloud (required for BigQuery)
GOOGLE_PROJECT_ID=your-gcp-project-id
GOOGLE_PRIVATE_KEY=your-service-account-private-key
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com

# Alternative: path to service account JSON file
# GOOGLE_SERVICE_ACCOUNT_FILE=./service-account/credentials.json

# BigQuery view for property monitor data
BQ_PROPERTY_MONITOR_VIEW=your-project.property_monitor.property_monitor_sales_view

# DuckDB paths (optional - defaults work for most setups)
DB_PATH=./data/database/dubai_land.db
PM_DB_PATH=./data/database/property_monitor.db

# API settings
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=INFO
DEBUG=false

# Content output directory
CONTENT_OUTPUT_DIR=./data/generated_content
